# ── DATABASE ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=caterflow

# ── JWT SECRET ───────────────────────────────────────────────
# Change this to a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_very_long_random_secret_string

# ── SERVER ───────────────────────────────────────────────────
PORT=5000

# ── FRONTEND URL (for CORS) ───────────────────────────────────
# Your React app domain, e.g. https://yourdomain.com
FRONTEND_URL=http://localhost:3000
